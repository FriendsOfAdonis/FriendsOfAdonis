{
  "name": "friends-of-adonis",
  "private": true,
  "workspaces": [
    "docs",
    "playgrounds/*",
    "packages/*",
    "tooling/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "play:graphql": "turbo dev --filter=playground-graphql...",
    "play:openapi": "turbo dev --filter=playground-openapi...",
    "play:actions": "turbo dev --filter=playground-actions...",
    "automd": "automd",
    "switch-catalog": "node --import=@poppinss/ts-exec ./tooling/scripts/switch-catalog.ts"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@foadonis/typescript-config": "workspace:*",
    "@manypkg/cli": "^0.25.1",
    "@poppinss/ts-exec": "^1.4.1",
    "automd": "^0.4.2",
    "mdbox": "^0.1.1",
    "node-gyp": "^12.1.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "turbo": "^2.7.3",
    "typescript": "^5.9.3",
    "yaml": "^2.8.2"
  },
  "resolutions": {
    "yargs": "^18.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "yarn@4.13.0",
  "manypkg": {
    "defaultBranch": "main"
  }
}
