{
  "name": "@foadonis/openapi",
  "version": "1.0.1",
  "description": "Generate OpenAPI specifications on Adonis",
  "keywords": [
    "adonis",
    "adonisjs",
    "api",
    "oapi",
    "openapi",
    "typescript"
  ],
  "homepage": "https://friendsofadonis.com/docs/openapi",
  "bugs": {
    "url": "https://github.com/FriendsOfAdonis/FriendsOfAdonis/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Martin Paucot",
    "email": "contact@martin-paucot.fr"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/FriendsOfAdonis/FriendsOfAdonis",
    "directory": "packages/openapi"
  },
  "files": [
    "build",
    "!build/bin",
    "!build/tests"
  ],
  "type": "module",
  "exports": {
    ".": "./build/index.js",
    "./commands": "./build/commands/main.js",
    "./openapi_provider": "./build/providers/openapi_provider.js",
    "./services/main": "./build/services/main.js",
    "./transformers": "./build/src/loaders/transformer.js",
    "./types": "./build/src/types.js",
    "./decorators": {
      "import": "./build/src/decorators.js",
      "types": "./build/src/decorators.d.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "scripts": {
    "clean": "del-cli build",
    "copy:templates": "cpy \"stubs/**/*.stub\" build/stubs",
    "index:commands": "adonis-kit index build/commands",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "quick:test": "node --import=./tsnode.esm.js --enable-source-maps bin/test.ts",
    "test": "c8 yarn quick:test",
    "build": "yarn clean && tsc && yarn copy:templates && yarn index:commands",
    "dev": "tsc --watch",
    "version": "yarn build"
  },
  "dependencies": {
    "@martin.xyz/openapi-decorators": "^0.1.2",
    "@standard-schema/spec": "^1.1.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@adonisjs/assembler": "catalog:",
    "@adonisjs/core": "catalog:",
    "@adonisjs/lucid": "catalog:",
    "@japa/assert": "^4.2.0",
    "@japa/expect-type": "^2.0.4",
    "@japa/file-system": "^3.0.0",
    "@japa/runner": "^4.5.0",
    "@swc/core": "1.15.5",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.0.2",
    "@types/sinon": "^21.0.0",
    "@vinejs/vine": "^4.2.0",
    "c8": "^11.0.0",
    "cpy-cli": "^7.0.0",
    "del-cli": "^7.0.0",
    "luxon": "^3.7.2",
    "openapi-types": "^12.1.3",
    "reflect-metadata": "^0.2.2",
    "ts-node": "^10.9.2",
    "type-fest": "^5.4.1",
    "typescript": "catalog:",
    "youch": "catalog:"
  },
  "peerDependencies": {
    "@adonisjs/core": "^6.2.0 || ^7.0.0",
    "@adonisjs/lucid": "^21.2.0 || ^22.0.0",
    "@vinejs/vine": "^3.0.0 || ^4.0.0",
    "luxon": "^3.5.0"
  },
  "c8": {
    "exclude": [
      "tests/**"
    ],
    "reporter": [
      "text",
      "html"
    ]
  },
  "engines": {
    "node": ">=20.6.0"
  }
}
