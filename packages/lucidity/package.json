{
  "name": "@foadonis/lucidity",
  "version": "0.0.1-next.0",
  "description": "Quality of life improvements for the Lucid ORM",
  "keywords": [
    "adonis",
    "adonisjs",
    "lucid",
    "typescript"
  ],
  "homepage": "https://friendsofadonis.com/docs/lucidity",
  "bugs": {
    "url": "https://github.com/FriendsOfAdonis/FriendsOfAdonis/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Martin Paucot",
    "email": "contact@martin-paucot.fr"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/FriendsOfAdonis/FriendsOfAdonis",
    "directory": "packages/lucidity"
  },
  "files": [
    "build",
    "!build/bin",
    "!build/tests"
  ],
  "type": "module",
  "exports": {
    ".": "./build/index.js",
    "./commands": "./build/commands/main.js",
    "./services/main": "./build/services/main.js",
    "./lucidity_provider": "./build/providers/lucidity_provider.js",
    "./types": "./build/src/types.js"
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "scripts": {
    "clean": "del-cli build",
    "copy:templates": "cpy \"stubs/**/*.stub\" build/stubs",
    "index:commands": "adonis-kit index build/commands",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "quick:test": "node --import=./tsnode.esm.js --enable-source-maps bin/test.ts",
    "test": "c8 yarn quick:test",
    "build": "yarn clean && tsc && yarn copy:templates && yarn index:commands",
    "dev": "tsc --watch",
    "version": "yarn build",
    "prepublishOnly": "yarn build"
  },
  "dependencies": {
    "@npmcli/package-json": "^7.0.4",
    "chalk": "^5.6.2",
    "cli-highlight": "^2.1.11",
    "deep-object-diff": "^1.1.9",
    "globby": "^16.1.0",
    "pkg-types": "^2.3.0",
    "ts-morph": "^27.0.2",
    "type-fest": "^5.3.1"
  },
  "devDependencies": {
    "@adonisjs/assembler": "catalog:",
    "@adonisjs/auth": "catalog:",
    "@adonisjs/core": "catalog:",
    "@adonisjs/lucid": "catalog:",
    "@apollo/client": "^4.0.11",
    "@japa/assert": "^4.2.0",
    "@japa/expect": "^3.0.7",
    "@japa/expect-type": "^2.0.4",
    "@japa/file-system": "^3.0.0",
    "@japa/runner": "^4.0.0",
    "@japa/snapshot": "^2.0.10",
    "@swc/core": "1.15.5",
    "@types/better-sqlite3": "^7.6.12",
    "@types/luxon": "^3.7.1",
    "@types/node": "catalog:",
    "@types/pg": "^8.11.0",
    "@types/sinon": "^21.0.0",
    "@types/wtfnode": "^0",
    "better-sqlite3": "^11.9.1",
    "c8": "^10.1.3",
    "cpy-cli": "^7.0.0",
    "del-cli": "^7.0.0",
    "luxon": "^3.7.2",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.2",
    "testcontainers": "^10.18.0",
    "ts-node": "^10.9.2",
    "typescript": "catalog:",
    "youch": "catalog:"
  },
  "peerDependencies": {
    "@adonisjs/core": "^7.0.0",
    "@adonisjs/lucid": "^22.0.0",
    "luxon": "^3.5.0"
  },
  "c8": {
    "exclude": [
      "tests/**"
    ],
    "reporter": [
      "text",
      "html"
    ]
  },
  "engines": {
    "node": ">=20.6.0"
  }
}
